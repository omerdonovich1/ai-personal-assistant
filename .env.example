# ─────────────────────────────────────────────────────────────────────────────
# AI Personal Assistant — environment variables
# Copy to `.env` and fill in. Only the CORE block is strictly required to boot.
# Everything else degrades gracefully (a missing integration just disables its
# tools; a missing DATABASE_URL falls back to local JSON files under data/).
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────────────────────
# Telegram bot token — create a bot with @BotFather, /newbot
TELEGRAM_BOT_TOKEN=

# Anthropic API key — https://console.anthropic.com/settings/keys
# Powers the agentic loop (Haiku/Sonnet/Opus, routed per message).
ANTHROPIC_API_KEY=

# Groq API key — https://console.groq.com/keys
# Used for voice-message transcription (Whisper) and image analysis.
GROQ_API_KEY=

# ── Memory / storage ─────────────────────────────────────────────────────────
# Postgres connection string. On Railway, reference the Postgres plugin.
# If unset → the bot runs in JSON-file fallback mode (data/ directory).
DATABASE_URL=

# Voyage AI key — https://dash.voyageai.com — embeddings for long-term
# vector memory (remember_context / recall_context). Unset → vector memory off.
VOYAGE_API_KEY=

# ── Productivity (Google: Calendar, Tasks, Gmail) ────────────────────────────
# OAuth client credentials JSON (one line). Get from Google Cloud Console →
# APIs & Services → Credentials → OAuth client ID (Desktop). Scopes needed:
# calendar, tasks, gmail.send + gmail.readonly.
GOOGLE_CREDENTIALS_JSON=

# OAuth token JSON (one line), produced after the first local `npm run bot`
# OAuth consent. Paste the resulting token here for Railway. Refreshes itself
# while valid; if it expires, re-auth locally and update this value.
GOOGLE_TOKEN_JSON=

# ── Search ───────────────────────────────────────────────────────────────────
# Brave Search API key — https://api-dashboard.search.brave.com
# Powers web_search / get_weather. Unset → web search disabled.
BRAVE_API_KEY=

# ── Deep work (optional integrations) ────────────────────────────────────────
# GitHub personal access token (repo scope) — https://github.com/settings/tokens
GITHUB_TOKEN=
# Comma-separated repos to surface in briefs, e.g. "owner/repo1,owner/repo2"
GITHUB_REPOS=

# Shopify Admin API access token + store domain (e.g. my-store.myshopify.com)
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_STORE=

# ── MCP (external tool servers) ──────────────────────────────────────────────
# JSON array of stdio MCP server specs. Their tools surface as
# mcp__<server>__<tool> alongside native tools. Unset → no extra servers.
# Example:
# MCP_SERVERS='[{"name":"fs","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/data"]}]'
MCP_SERVERS=

# ── Scheduling ───────────────────────────────────────────────────────────────
# Telegram chat ID that scheduled messages (briefs, reviews) are sent to.
# Auto-captured on first interaction (persisted to data/chat-id.json), but you
# can pin it explicitly here.
TELEGRAM_CHAT_ID=

# ── Dashboard (Mission Control — see dashboard/) ─────────────────────────────
# DASHBOARD_SECRET — any long random string; gates the dashboard via ?key=...
# DATABASE_URL — same Postgres as the bot. (Both set on the dashboard service.)
DASHBOARD_SECRET=
